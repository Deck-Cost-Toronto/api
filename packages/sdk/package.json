{
  "name": "@deckcosttoronto/sdk",
  "version": "0.1.0",
  "description": "Tiny TypeScript client for the Deck Cost Toronto API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "../../LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "deck",
    "deck-cost",
    "toronto",
    "gta",
    "construction",
    "estimate",
    "calculator",
    "api",
    "sdk"
  ],
  "homepage": "https://deckcosttoronto.com/developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deck-Cost-Toronto/api.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Deck-Cost-Toronto/api/issues"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
